{
  "name": "todo-electron",
  "version": "1.0.0",
  "description": "Full-stack Electron task manager with nested subtasks",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "backend:start": "node backend/src/server.js",
    "db:migrate": "node backend/scripts/migrate.js",
    "db:seed": "node backend/scripts/seed.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "build:electron": "electron-builder --dir",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.todoelectron.app",
    "productName": "Todo Electron",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "backend/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "sign": false
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pg-mem": "^3.0.5",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
